  firewall.network = {
    wan0Mac = "aa:bb:cc:dd:ee:01";
    lan1Mac = "aa:bb:cc:dd:ee:02";
    lan2Mac = "aa:bb:cc:dd:ee:03";
    lan3Mac = "aa:bb:cc:dd:ee:04";
  };

  firewall.mullvad = {
    endpoint  = "185.213.154.68";
    port      = 51820;
    serverKey = "YOUR_MULLVAD_SERVER_PUBLIC_KEY";
    address   = "10.68.1.42/32";
  };
